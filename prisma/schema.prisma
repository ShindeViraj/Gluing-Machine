generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model machine_print_log {
  id            BigInt   @id @default(autoincrement())
  operator_name String   @db.VarChar(50)
  plc_datetime  DateTime @unique(map: "uq_plc_datetime")
  mode_auto     Boolean  @default(false)
  mode_manual   Boolean  @default(false)
  print_done    Boolean  @default(false)
  created_at    DateTime @default(now())

  @@index([plc_datetime], map: "idx_datetime")
  @@index([operator_name], map: "idx_operator")
}
